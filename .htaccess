# Root .htaccess — subfolder: domain.com/wicara/
RewriteEngine On

# Jangan redirect jika sudah ke /wicara/public
RewriteCond %{REQUEST_URI} !^/wicara/public/

# Jangan redirect file/folder yang benar-benar ada
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Teruskan ke /wicara/public
RewriteRule ^(.*)$ /wicara/public/$1 [L,QSA]
