Options -Indexes
RewriteEngine On

# ── 1. Izinkan file & folder fisik (CSS, JS, gambar, uploads) ──────────────
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# ── 2. Teruskan semua request lain ke index.php (front controller) ─────────
RewriteRule ^ index.php [L,QSA]
